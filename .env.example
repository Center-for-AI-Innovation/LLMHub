# API settings
API_V1_STR=/api
PROJECT_NAME="AI Inference Backend"

# CORS settings
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Database settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llm_service

# HPC settings
SLURM_ACCOUNT="your_slurm_account"
VEC_INF_ACCOUNT="your_slurm_account"
VEC_INF_WORK_DIR=/path/to/workdir
# Comma-separated KEY=VALUE pairs that are forwarded into the container job environment.
# Example: HF_HOME=/root/.cache/huggingface,HF_HUB_CACHE=/root/.cache/huggingface/hub
VEC_INF_ENV=

# Background service settings
SYNC_INTERVAL=600
EXPIRY_CHECK_INTERVAL=3000
MAX_DEPLOYMENTS_PER_CYCLE=10
