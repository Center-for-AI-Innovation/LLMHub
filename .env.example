# =============================================================================
# LLM Serving Frontend Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# Never commit your .env.local file to version control.

# =============================================================================
# Authentication (Better Auth + CILogon)
# =============================================================================
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret-here
# Public app URL used by Better Auth
BETTER_AUTH_URL=http://localhost:3000

# CILogon OIDC configuration
CILOGON_CLIENT_ID=
CILOGON_CLIENT_SECRET=
CILOGON_DISCOVERY_URL=https://cilogon.org/.well-known/openid-configuration
CILOGON_SKIN=illinois-chat

# =============================================================================
# Database (PostgreSQL with Drizzle)
# =============================================================================
# PostgreSQL connection URL
POSTGRES_URL=postgresql://user:password@localhost:5432/llmhub

# =============================================================================
# vLLM Configuration
# =============================================================================
# vLLM server URL (OpenAI-compatible endpoint)
# This is the base URL for the vLLM server's OpenAI-compatible API
VLLM_BASE_URL=http://localhost:8000/v1

# API key for vLLM (vLLM doesn't require one by default)
VLLM_API_KEY=dummy-key

# Default model name as registered in vLLM
# This should match the model name returned by the vLLM server's /v1/models endpoint
VLLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Always-on public chat model (required for guest/always-on chat path)
ALWAYS_ON_VLLM_BASE_URL=http://localhost:8000/v1
ALWAYS_ON_VLLM_API_KEY=dummy-key
ALWAYS_ON_VLLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# ============================================================================
# Pepper to store user API keys securely
USER_API_KEY_PEPPER=your-user-api-key-pepper
# =============================================================================
# Backend API Configuration
# =============================================================================
# Backend API URL for model deployments and management
# This is the URL of the llm-serving-backend FastAPI service
BACKEND_API_URL=http://localhost:8000


# =============================================================================
# OpenAI Configuration (Optional)
# =============================================================================
# Required for chat-model-small and other OpenAI-based models
# OPENAI_API_KEY=sk-your-openai-api-key

# =============================================================================
# Development Configuration (Optional)
# Local test deployment mode (disabled by default)
# Set to true only if you want the frontend to use /api/test/local/deployments
# =============================================================================
NEXT_PUBLIC_USE_LOCAL_TEST_DEPLOYMENTS=false
DEV_VLLM_ENDPOINT=http://localhost:8000/v1
DEV_VLLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# =============================================================================
# S3-Compatible Storage (for attachments)
# =============================================================================
# Works with AWS S3, MinIO, Cloudflare R2, etc.
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
# Optional (required for MinIO/R2/custom endpoints)
S3_ENDPOINT=
# Optional (set true for MinIO path-style)
S3_FORCE_PATH_STYLE=false
# Signed URL TTL in seconds (default: 900)
S3_SIGNED_URL_TTL_SECONDS=900
