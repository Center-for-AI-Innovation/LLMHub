# API settings
API_V1_STR=/api
PROJECT_NAME="AI Inference Backend"

# CORS settings
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Database settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llm_service

# HPC settings
SLURM_ACCOUNT="your_slurm_account"
VEC_INF_ACCOUNT="your_slurm_account"
VEC_INF_CONFIG_DIR=/sw/llmhub/llm-serving-backend-config
VEC_INF_WORK_DIR=/path/to/workdir
VEC_INF_LOG_DIR=/path/to/logdir
VEC_INF_SHARED_WORK_ROOT=/projects/llmhub
VEC_INF_EXECUTION_MODE=direct
# VEC_INF_IMPERSONATE_SCRIPT=/path/to/llm-serving-backend/scripts/impersonate-wrapper.py
# VEC_INF_IMPERSONATE_PYTHON=/sw/llmhub/<shared-env>/bin/python
# VEC_INF_IMPERSONATE_LOGIN_SHELL=true
# VEC_INF_ACCOUNTS_SCRIPT=/sw/user/scripts/accounts
# Comma-separated KEY=VALUE pairs that are forwarded into the container job environment.
# Example: HF_HOME=/root/.cache/huggingface,HF_HUB_CACHE=/root/.cache/huggingface/hub
VEC_INF_ENV=

# Background service settings
SYNC_INTERVAL=600
EXPIRY_CHECK_INTERVAL=3000
MAX_DEPLOYMENTS_PER_CYCLE=10
