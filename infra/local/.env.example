# Copy to .env to override the development defaults in compose.yaml.
# Secrets from the legacy repositories are intentionally not copied here.

POSTGRES_DB=llm_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

FRONTEND_PORT=3000
BACKEND_PORT=8000
VLLM_PORT=8001

# ARM64 CPU default for Apple Silicon. For an NVIDIA Linux host, use:
# VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_IMAGE=vllm/vllm-openai-cpu:latest-arm64
VLLM_MODEL=Qwen/Qwen3.5-2B
VLLM_MAX_MODEL_LEN=4096
VLLM_DTYPE=auto
VLLM_MEMORY_UTILIZATION=0.65

# Only needed for gated/private Hugging Face models.
HF_TOKEN=

# Replace these if the stack is exposed beyond your workstation.
BETTER_AUTH_SECRET=local-development-secret-change-before-sharing
USER_API_KEY_PEPPER=local-development-pepper-change-before-sharing
VLLM_API_KEY=local-vllm
